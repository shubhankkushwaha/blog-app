<div style="max-width:400px; margin:auto; background:#1e293b; padding:20px; border-radius:10px;">

<h2 style="text-align:center;">Create User</h2>

<% if @user.errors.any? %>
  <div style="background:#ef4444; padding:10px; margin-bottom:10px;">
    <ul>
      <% @user.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model:@user do |f| %>

  <div>
    <%= f.label :name %><br>
    <%= f.text_field :name, style:"width:100%; padding:8px; margin-bottom:10px;" %>
  </div>

  <div>
    <%= f.label :email %><br>
    <%= f.text_field :email, style:"width:100%; padding:8px; margin-bottom:10px;" %>
  </div>

  <%= f.submit "Create User", style:"width:100%; background:#e11d48; color:white; padding:10px; border:none;" %>

<% end %>

</div>  

